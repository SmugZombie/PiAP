# /etc/sudoers.d/piap
# Allow the piap service user to run only the specific scripts it needs, as root, without a password.
# This file is installed by install.sh.

piap ALL=(root) NOPASSWD: /opt/piap/scripts/apply-profile.sh
piap ALL=(root) NOPASSWD: /opt/piap/scripts/stop-ap.sh
piap ALL=(root) NOPASSWD: /opt/piap/scripts/apply-admin-ap.sh
piap ALL=(root) NOPASSWD: /opt/piap/scripts/stop-admin-ap.sh
piap ALL=(root) NOPASSWD: /usr/bin/systemctl start hostapd
piap ALL=(root) NOPASSWD: /usr/bin/systemctl stop hostapd
piap ALL=(root) NOPASSWD: /usr/bin/systemctl start dnsmasq
piap ALL=(root) NOPASSWD: /usr/bin/systemctl stop dnsmasq
piap ALL=(root) NOPASSWD: /usr/bin/systemctl start hostapd-admin
piap ALL=(root) NOPASSWD: /usr/bin/systemctl stop hostapd-admin
piap ALL=(root) NOPASSWD: /usr/bin/systemctl reload-or-restart dnsmasq
piap ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
